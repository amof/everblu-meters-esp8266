#ifndef SECRETS_H
#define SECRETS_H

/**
 * Copy this file to `include/secrets.h` and fill it in. That copy is
 * gitignored, so `git status` stays clean once the device is configured.
 *
 * Everything deployment-specific lives here, not only the credentials. The
 * point is that no tracked source file ever needs a local edit — which is what
 * keeps a real WiFi password from arriving in a commit via `git add -A`.
 */

// --- Network ---------------------------------------------------------------
#define WIFI_SSID "WifiSSID"
#define WIFI_PASSWORD "WifiPassword"

// --- MQTT ------------------------------------------------------------------
#define MQTT_SERVER "myMqttServer"
#define MQTT_USERNAME "MQTTUsername" // Empty string if the broker is open
#define MQTT_PASSWORD "MQTTPassword" // Empty string if the broker is open

// Identifies this device to the broker, and — because EspMQTTClient passes it
// to ArduinoOTA.setHostname() — it is also the mDNS name you flash to. Keep it
// in step with `upload_port` in platformio_local.ini.
#define MQTT_CLIENT_NAME "everblu-cyble"

// --- Over-the-air updates --------------------------------------------------
// Anything on the LAN can reach the OTA port, so this is the only thing
// stopping a neighbour's compromised bulb from reflashing the meter reader.
// Do not leave it empty: EspMQTTClient silently falls back to MQTT_PASSWORD.
#define OTA_PASSWORD "choose-an-ota-password"

// --- Time ------------------------------------------------------------------
#define NTP_SERVER "myNtpServer"
// POSIX TZ string, not an IANA name. The sign is inverted: CET-1 means UTC+1.
// https://github.com/nayarsystems/posix_tz_db/blob/master/zones.csv
#define TZ_STRING "CET-1CEST,M3.5.0,M10.5.0/3" // Europe/Brussels

// --- Meter -----------------------------------------------------------------
#define METER_YEAR 20       // Two-digit year from the meter label
#define METER_SERIAL 123456 // Serial WITHOUT any leading zero: a leading zero
                            // makes this an octal literal and silently changes
                            // the value (or fails to compile on an 8 or 9).

// --- Wiring ----------------------------------------------------------------
#define GDO0_PIN 5 // GPIO wired to the CC1101 GDO0 pin. 5 is D1.

#endif // SECRETS_H
